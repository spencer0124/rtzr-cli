{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rtzr-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-14",
  "compatibility_flags": ["nodejs_compat"],
  // Adding a custom-domain route otherwise disables the *.workers.dev URL by
  // default — keep both live, since both are documented in the READMEs.
  "workers_dev": true,
  // Stateless MCP server (createMcpHandler, no McpAgent/Durable Objects) — see
  // CLAUDE.md's mcp-worker section and docs/concept.md §8.2 for why.
  //
  // Live at both https://rtzr-mcp.zoyoong124.workers.dev/mcp (default) and
  // https://rtzr.seungyongcho.com/mcp (custom domain, attached 2026-07-14 via
  // the Cloudflare dashboard). Declared here too so a clean `wrangler deploy`
  // reproduces the same routing instead of only living in the dashboard.
  // Custom Domains take a bare hostname only — no wildcard/path, unlike zone Routes.
  "routes": [{ "pattern": "rtzr.seungyongcho.com", "custom_domain": true }],
  // Backs request_upload_url / GET,PUT /uploads/:id (src/uploadUrl.ts) — a
  // presigned direct-upload flow that replaced the earlier KV-based
  // upload_chunk tool, which didn't actually solve the problem (see
  // LESSONS.md #9): chunking a base64 blob doesn't reduce the total text the
  // *calling model* has to generate, only the size of any one piece.
  "r2_buckets": [{ "binding": "UPLOADS_R2", "bucket_name": "rtzr-uploads" }]
}
